apt-get update
DEBIAN_FRONTEND=noninteractive apt-get install -y \
  make squashfs-tools debootstrap \
  qemu-kvm qemu-utils expect sshpass mtools zstd \
  initramfs-tools sudo kmod iproute2 iputils-ping \
  openssh-server ca-certificates curl gpg locales logrotate \
  dbus
systemctl enable ssh systemd-networkd
echo "root:root" | chpasswd
sed -i 's/^%sudo.*/%sudo ALL=(ALL) NOPASSWD:ALL/' /etc/sudoers
echo "Defaults env_keep += \"DEBIAN_FRONTEND\"" >> /etc/sudoers
